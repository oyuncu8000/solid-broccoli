{
  "version": 2,
  "functions": {
    "video/*.php": {
      "runtime": "vercel-php@0.7.1"
    },
    "api/*.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "routes": [
    {
      "src": "/video/(.*).php",
      "dest": "/video/$1.php"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.tsx"
    }
  ]
}